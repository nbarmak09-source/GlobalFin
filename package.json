{
  "name": "gcm-hq",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 10240 2>/dev/null; next dev -p 3000 -H 127.0.0.1",
    "db:fix-rls-checksum": "node scripts/fix-rls-migration-checksum.cjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "audit": "npm audit",
    "postinstall": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:try-urls": "node scripts/try-prisma-migrate-urls.cjs",
    "db:url": "node scripts/db-url.cjs",
    "db:url:set": "node scripts/db-url.cjs set",
    "db:url:vercel-pull": "node scripts/db-url.cjs vercel-pull",
    "db:url:vercel-push": "node scripts/db-url.cjs vercel-push",
    "db:doctor": "node scripts/db-url.cjs doctor",
    "playwright:install": "env -u PLAYWRIGHT_BROWSERS_PATH npx playwright install chromium",
    "screenshots:mobile": "env -u PLAYWRIGHT_BROWSERS_PATH node mobile-screenshots.mjs",
    "pack:mobile-review": "bash scripts/pack-mobile-review-bundle.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/d3": "^7.4.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "docx": "^9.6.1",
    "html2canvas": "^1.4.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.575.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "resend": "^6.9.3",
    "xlsx": "^0.18.5",
    "yahoo-finance2": "^3.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/d3-sankey": "^0.12.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "playwright": "^1.59.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.10",
    "@hono/node-server": "1.19.13"
  }
}
