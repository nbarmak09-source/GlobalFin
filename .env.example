# Copy this file to .env (for Prisma CLI and local dev) or .env.local (Next.js).
# Using .env for local dev ensures both `npx prisma migrate` and the Next.js app see your variables.
# Do not commit .env or .env.local.

# -----------------------------------------------------------------------------
# Supabase (PostgreSQL)
# -----------------------------------------------------------------------------
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Session mode" pooler (port 5432) so migrations and the app both work.
#
# Format: postgres://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres
# Example: postgres://postgres.abcdefgh:mySecretPassword@aws-0-us-east-1.pooler.supabase.com:5432/postgres
#
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Resend (verification emails for signup)
# -----------------------------------------------------------------------------
# Get an API key from https://resend.com → API Keys
# Without this, signup will create accounts but verification emails will not be sent.
#
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Optional: verified sender (defaults to onboarding@resend.dev for testing)
# EMAIL_FROM="noreply@yourdomain.com"

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
# In production use https and a strong secret: e.g. openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-string"

# Optional: OAuth providers
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_ID=""
# GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# FRED (Federal Reserve Economic Data — macro indicators)
# -----------------------------------------------------------------------------
# Get a free API key from https://fred.stlouisfed.org/docs/api/api_key.html
# Without this, the Macro Indicators section on the dashboard will show placeholder data.
#
FRED_API_KEY="your-fred-api-key"

# -----------------------------------------------------------------------------
# Anthropic (AI features: chat, pitch generation)
# -----------------------------------------------------------------------------
# Get an API key from https://console.anthropic.com
# Without this, chat and AI-powered features will fail or show an error.
#
# ANTHROPIC_API_KEY="sk-ant-..."

# -----------------------------------------------------------------------------
# SEC EDGAR (optional — annual fundamentals on Models / DCF)
# -----------------------------------------------------------------------------
# SEC requires a descriptive User-Agent string with contact info.
# If omitted, a default is used. Set this in production to your real contact URL/email.
#
# SEC_USER_AGENT="YourApp/1.0 (https://yoursite.com; you@yoursite.com)"
